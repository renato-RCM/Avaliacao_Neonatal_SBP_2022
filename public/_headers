# Cloudflare Pages — headers de seguranca e cache.
# Espelha o que o nginx.conf faz no deploy via Docker.

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Assets com hash do Vite (immutable) — cache por 1 ano.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# index.html nunca cacheia — deploy reflete imediato.
/index.html
  Cache-Control: no-store, no-cache, must-revalidate

# Favicon e SVGs avulsos — cache curto.
/*.svg
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800
